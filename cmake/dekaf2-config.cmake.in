# dekaf2-config.cmake - package configuration file

cmake_policy(PUSH)

if (CMAKE_VERSION VERSION_GREATER_EQUAL 3.27.0)
	# use case-preserved package root variable names (Boost_ROOT instead of BOOST_ROOT)
	cmake_policy(SET CMP0144 NEW)
	# accept upper-case BOOST_ROOT from caller
	if (NOT Boost_ROOT AND BOOST_ROOT)
		set(Boost_ROOT "${BOOST_ROOT}")
	endif()
endif()

if (CMAKE_VERSION VERSION_GREATER_EQUAL 3.30.0)
	# use boosts own BoostConfig.cmake
	cmake_policy(SET CMP0167 OLD)
endif()

include(CMakeFindDependencyMacro)

# the required dependencies
find_dependency(Threads)
find_dependency(OpenSSL)
set(Boost_NO_WARN_NEW_VERSIONS ON)
find_dependency(Boost COMPONENTS iostreams serialization)
if (@DEKAF2_HAS_LIBYAML@) # DEKAF2_HAS_LIBYAML
	find_dependency(yaml-cpp)
endif()

# external libs dekaf2 may have been built against via find_package. Only pull them in here
# when NOT vendored - a vendored copy is bundled into dekaf2-targets.cmake instead.
if (@DEKAF2_USE_SYSTEM_FMTLIB@) # DEKAF2_USE_SYSTEM_FMTLIB
	find_dependency(fmt CONFIG)
endif()
if (NOT @DEKAF2_USE_VENDORED_NLOHMANN@) # DEKAF2_USE_VENDORED_NLOHMANN
	find_dependency(nlohmann_json 3.11.2 CONFIG)
endif()
if (NOT @DEKAF2_USE_VENDORED_DATE@) # DEKAF2_USE_VENDORED_DATE
	find_dependency(date CONFIG)
endif()
if (@DEKAF2_WITH_SIMDUTF@ AND NOT @DEKAF2_USE_VENDORED_SIMDUTF@) # simdutf via find_package
	find_dependency(simdutf CONFIG)
endif()

# in package/vcpkg mode the system libraries are linked through their imported targets (see the
# matching block in CMakeLists.txt), so the consumer has to recreate those targets here. In the
# normal build they are baked into dekaf2-targets.cmake as absolute paths and need nothing.
if (@DEKAF2_VCPKG_BUILD@) # DEKAF2_VCPKG_BUILD
	find_dependency(ZLIB)
	find_dependency(BZip2)
	if (@DEKAF2_HAS_LIBLZMA@)
		find_dependency(LibLZMA)
	endif()
	if (@DEKAF2_HAS_LIBZSTD@)
		find_dependency(zstd CONFIG)
	endif()
	if (@DEKAF2_HAS_LIBBROTLI@)
		find_dependency(unofficial-brotli CONFIG)
	endif()
	if (@DEKAF2_HAS_NGHTTP2@)
		find_dependency(PkgConfig)
		pkg_check_modules(dekaf2_nghttp2 REQUIRED IMPORTED_TARGET libnghttp2)
	endif()
endif()

cmake_policy(POP)

if (@DEKAF2_DUAL_TARGET@) # DEKAF2_DUAL_TARGET
	# we only support the Release and Debug output locations - other
	# build types have to pick either or
	if (CMAKE_BUILD_TYPE STREQUAL "Debug"
	 OR CMAKE_BUILD_TYPE STREQUAL "debug")
		set(LIB_BUILD_TYPE_PATH "/../Debug/cmake")
	elseif (NOT CMAKE_BUILD_TYPE AND NOT "@CMAKE_BUILD_TYPE@" STREQUAL "")
		set(LIB_BUILD_TYPE_PATH "/../@CMAKE_BUILD_TYPE@/cmake")
	else()
		set(LIB_BUILD_TYPE_PATH "/../Release/cmake")
	endif()
else() # DEKAF2_DUAL_TARGET
	# simply leave the output path empty when we output only to one target location
	# (we are already inside the lib/dekaf2/cmake directory..)
	set(LIB_BUILD_TYPE_PATH)
endif() # DEKAF2_DUAL_TARGET

get_filename_component(SELF_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)
include("${SELF_DIR}${LIB_BUILD_TYPE_PATH}/dekaf2-targets.cmake")
include("${SELF_DIR}${LIB_BUILD_TYPE_PATH}/dekaf2-setup.cmake")
