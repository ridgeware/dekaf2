PROJECT_NAME           = "@CMAKE_PROJECT_NAME@"
PROJECT_NUMBER         = @VERSION_MAJOR@.@VERSION_MINOR@.@VERSION_PATCH@
PROJECT_BRIEF          = "Lighter, Faster, Smarter"
STRIP_FROM_PATH        = @PROJECT_SOURCE_DIR@ \
                         @PROJECT_BINARY_DIR@
# STRIP_FROM_INC_PATH    = @@
INPUT                  = @PROJECT_SOURCE_DIR@ \
                         @PROJECT_SOURCE_DIR@/doc/modules.dox
FILE_PATTERNS          = *.h   \
                         *.hpp \
                         *.cpp \
                         *.dox
EXCLUDE_PATTERNS       = @PROJECT_SOURCE_DIR@/benchmarks/*  \
                         @PROJECT_SOURCE_DIR@/cmake/*       \
                         @PROJECT_SOURCE_DIR@/compat/*      \
                         @PROJECT_SOURCE_DIR@/debug/*       \
                         @PROJECT_SOURCE_DIR@/doc/*         \
                         @PROJECT_SOURCE_DIR@/from/*        \
                         @PROJECT_SOURCE_DIR@/libs/*        \
                         @PROJECT_SOURCE_DIR@/samples/*     \
                         @PROJECT_SOURCE_DIR@/scripts/*     \
                         @PROJECT_SOURCE_DIR@/smoketests/*  \
                         @PROJECT_SOURCE_DIR@/templates/*   \
                         @PROJECT_SOURCE_DIR@/utests/*
RECURSIVE              = YES
HAVE_DOT               = @DOXYGEN_DOT_FOUND@
# USE_MDFILE_AS_MAINPAGE = @doxy_main_page@
OUTPUT_LANGUAGE        = English
BUILTIN_STL_SUPPORT    = YES
BRIEF_MEMBER_DESC      = YES
# repeat brief in detail section
REPEAT_BRIEF           = NO
# create details if only brief?
ALWAYS_DETAILED_SEC    = YES
# show inherited members in child class?
INLINE_INHERITED_MEMB  = YES
# is multiline /// allowed for brief?
MULTILINE_CPP_IS_BRIEF = YES
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = YES
HIDE_SCOPE_NAMES       = YES
EXTENSION_MAPPING      = h=C++
INLINE_SIMPLE_STRUCTS  = YES
NUM_PROC_THREADS       = 0
DOT_NUM_THREADS        = 0
# the inline keyword is useless nowadays, do not highlight it
INLINE_INFO            = NO
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = NO
HIDE_FRIEND_COMPOUNDS  = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SORT_MEMBERS_CTORS_1ST = YES
SORT_GROUP_NAMES       = YES
COLS_IN_ALPHA_INDEX    = 3
IGNORE_PREFIX          = K
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = NO
REFERENCES_RELATION    = NO
HIDE_UNDOC_RELATIONS   = NO
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = NO
HTML_TIMESTAMP         = YES
HTML_DYNAMIC_SECTIONS  = NO
GENERATE_TREEVIEW      = YES
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = DEKAF2_GSL_OWNER()= DEKAF2_GSL_POINTER()= DEKAF2_PUBLIC= DEKAF2_PRIVATE= \
 DEKAF2_NODISCARD= DEKAF2_FALLTHROUGH= \
 __clang__=10 __unix__=1 __cplusplus=202003L __cpp_lib_chrono=202003L \
 OPENSSL_VERSION_NUMBER=0x030000000L \
 DEKAF=2 DEKAF_VERSION=2 DEKAF2_USE_BOOST_MULTI_INDEX= DEKAF2_USE_KPROPS_MULTI_INDEX= \
 DEKAF2_USE_KMRU_MULTI_INDEX= DEKAF2_USE_FBSTRING_AS_KSTRING= DEKAF2_USE_OPTIMIZED_STRING_FIND= \
 DEKAF2_HAS_MINIFOLLY= DEKAF2_HAS_FROZEN= DEKAF2_USE_FROZEN_HASH_FOR_LARGE_MAPS= \
 DEKAF2_HAS_MYSQL= DEKAF2_HAS_SQLITE3= DEKAF2_HAS_FREETDS= DEKAF2_HAS_CTLIB= \
 DEKAF2_HAS_LIBZIP= DEKAF2_HAS_LIBBROTLI= DEKAF2_HAS_LIBZSTD= DEKAF2_HAS_LIBLZMA= \
 DEKAF2_HAS_INCOMPLETE_BOOST_IOSTREAMS_LZMA_BUILD= \
 DEKAF2_HAS_AES=1 DEKAF2_HAS_HKDF=1 DEKAF2_HAS_ARIA=1 DEKAF2_HAS_BLAKE2=1 \
 DEKAF2_HAS_NGHTTP2=1 DEKAF2_HAS_NGHTTP3=1 DEKAF2_HAS_OPENSSL_QUIC=1 \
 DEKAF2_HAS_SYSLOG= DEKAF2_HAS_USER_AGENT_PARSER=1 DEKAF2_HAS_INT128= \
 DEKAF2_WITH_KLOG= DEKAF2_KLOG_WITH_TCP= DEKAF2_HAS_UNIX_SOCKETS= DEKAF2_HAS_PIPES= \
 DEKAF2_HAS_CPP_14=1 DEKAF2_HAS_CPP_17=1 DEKAF2_HAS_CPP_20=1 \
 DEKAF2_HAS_FULL_CPP_17=1 DEKAF2_HAS_FULL_CPP_20=1 DEKAF2_HAS_CONSTEXPR_IF=1 \
 DEKAF2_HAS_STD_STRING_VIEW=1 DEKAF2_HAS_STD_FILESYSTEM=1 DEKAF2_HAS_STD_VARIANT=1 \
 DEKAF2_HAS_CONCEPTS=1 DEKAF2_HAS_SPACESHIP_OPERATOR=1 \
 DEKAF2_HAS_CHRONO_CALENDAR=1 DEKAF2_HAS_TIMEZONES=1 DEKAF2_HAS_CHRONO_ROUND=1 \
 DEKAF2_HAS_NANOSECONDS_SYS_CLOCK=1 \
 DEKAF2_HAS_STD_FORMAT=1 DEKAF2_HAS_FMT_FORMAT=1 DEKAF2_HAS_FORMAT_RUNTIME=1 \
 DEKAF2_NAMESPACE_BEGIN="namespace dekaf2 {" DEKAF2_NAMESPACE_END="}"
LAYOUT_FILE            = @PROJECT_SOURCE_DIR@/doc/DoxygenLayout.xml
HTML_HEADER            = @PROJECT_SOURCE_DIR@/doc/header.html
HTML_EXTRA_STYLESHEET  = @PROJECT_SOURCE_DIR@/doc/doxygen-awesome-css/doxygen-awesome.css \
                         @PROJECT_SOURCE_DIR@/doc/doxygen-awesome-css/doxygen-awesome-sidebar-only.css \
                         @PROJECT_SOURCE_DIR@/doc/doxygen-awesome-css/doxygen-awesome-sidebar-only-darkmode-toggle.css \
                         @PROJECT_SOURCE_DIR@/doc/custom.css
HTML_EXTRA_FILES       = @PROJECT_SOURCE_DIR@/doc/doxygen-awesome-css/doxygen-awesome-darkmode-toggle.js \
                         @PROJECT_SOURCE_DIR@/doc/doxygen-awesome-css/doxygen-awesome-interactive-toc.js
HTML_COLORSTYLE        = LIGHT
HTML_COLORSTYLE_HUE    = 209
HTML_COLORSTYLE_SAT    = 255
HTML_COLORSTYLE_GAMMA  = 113
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO
GENERATE_DOCBOOK       = NO
ENABLE_PREPROCESSING   = YES
UML_LOOK               = NO
TEMPLATE_RELATIONS     = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
INTERACTIVE_SVG        = YES
